{
  "manifest_version": 3,
  "name": "TrueSight AI",
  "short_name": "TrueSight",
  "version": "1.0.0",
  "description": "Think. Verify. Understand. Then Share. Detects manipulation techniques in news, ads, and posts — in Arabic and English.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*"]
}
