# Copy this file to .env in the same folder: cp .env.example .env
# (Windows: copy .env.example .env)
#
# The defaults below already give you a FREE, fully local setup using Llama
# through Ollama — you do NOT need to fill anything in to get started,
# as long as you've installed Ollama and run `ollama pull llama3.1:8b`.

# ── Which engine to use ─────────────────────────────────────────────────
# "ollama"    = free, local Llama, no API key, no cost. DEFAULT.
# "anthropic" = paid Claude API, needs a real key below. Higher quality,
#               costs a small amount per request.
ENGINE_BACKEND=ollama

# ── Ollama settings (only matter if ENGINE_BACKEND=ollama) ─────────────
# Must match a model you've pulled: ollama pull llama3.1:8b
OLLAMA_MODEL=llama3.1:8b
# Default Ollama address — only change this if you moved Ollama elsewhere.
OLLAMA_URL=http://localhost:11434/api/chat

# ── Anthropic settings (only matter if ENGINE_BACKEND=anthropic) ───────
# Get a key at console.anthropic.com — costs money per request, unlike Ollama.
# ANTHROPIC_API_KEY=your_key_here
# TRUESIGHT_MODEL=claude-haiku-4-5-20251001
